              "expr": "format('[System.Net.ServicePointManager]::ServerCertificateValidationCallback = {{$true}}\n\n# Gunakan variable agar lebih rapi\n$apiKey = ''{0}''.Trim()\n$policyPath = \"policies/scm.yml\"\n\n$authUri = \"{1}/authn/{2}/{3}/authenticate\"\n$policyUri = \"{4}/policies/{5}/policy/root\"\n\n# 1. Ambil Token\nWrite-Host \"Sedang mengautentikasi {6}...\"\n$token = Invoke-RestMethod -Method Post -Uri $authUri -Body $apiKey -ContentType \"text/plain\"\n\n# 2. Encode Token ke Base64\n$tokenBytes = [System.Text.Encoding]::UTF8.GetBytes($token)\n$base64Token = [Convert]::ToBase64String($tokenBytes)\n\n$headers = @{{\n    \"Authorization\" = \"Token token=`\"$base64Token`\"\"\n}}\n\n# 3. Kirim Policy\nWrite-Host \"Mengirim policy $policyPath ke Conjur...\"\n$policyContent = Get-Content -Raw -Path $policyPath\nInvoke-RestMethod -Method Post -Uri $policyUri -Headers $headers -Body $policyContent -ContentType \"text/plain\"\n\nWrite-Host \"BERHASIL! Policy terupdate dan teraudit.\"', secrets.CONJUR_API_KEY, vars.CONJUR_URL, vars.CONJUR_ACCOUNT, vars.CONJUR_USERNAME, vars.CONJUR_URL, vars.CONJUR_ACCOUNT, vars.CONJUR_USERNAME)"
